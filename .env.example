# ContentGuardian environment variables
#
# ALL OPTIONAL. With no variables set, the app runs in deterministic MOCK mode:
# agents return scripted-but-realistic outputs and embeddings use feature hashing,
# so `npm install && npm run db:seed && npm run dev` works end-to-end with zero
# external services. See README "Architecture Decisions".

# Set a Gemini API key to switch agents + embeddings to live Google Gemini.
# Get one at https://aistudio.google.com/apikey
# GOOGLE_GENERATIVE_AI_API_KEY=your_key_here

# Optional: override the SQLite database file path (default ./contentguardian.db)
# DATABASE_PATH=./contentguardian.db
